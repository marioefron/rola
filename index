<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Rola</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{
  background:#fff;color:#111;
  font-family:'Space Mono',monospace;
  height:100dvh;display:flex;flex-direction:column;
  overflow:hidden;user-select:none;touch-action:none;
}

/* ── TOP BAR ── */
.topbar{
  display:flex;align-items:center;gap:0;
  border-bottom:1px solid #e0e0e0;
  flex-shrink:0;background:#fff;
  flex-wrap:wrap;
}

/* Row 1: logo + bpm + edit */
.row1{
  display:flex;align-items:center;
  width:100%;padding:8px 12px;gap:10px;
  border-bottom:1px solid #ebebeb;
}
.logo{
  font-family:'Space Mono',monospace;
  font-weight:700;font-size:13px;
  letter-spacing:.08em;text-transform:uppercase;
  color:#111;flex-shrink:0;
}
.bpm-ctrl{
  display:flex;align-items:center;gap:6px;
  font-size:10px;color:#aaa;flex:1;
}
.bpm-ctrl input[type=range]{
  -webkit-appearance:none;flex:1;max-width:80px;
  height:2px;background:#ddd;border-radius:1px;outline:none;
}
.bpm-ctrl input[type=range]::-webkit-slider-thumb{
  -webkit-appearance:none;width:12px;height:12px;
  border-radius:50%;background:#111;cursor:pointer;
}
#bpm-v{color:#111;font-weight:700;min-width:24px;font-size:10px;}
.edit-btn{
  font-family:'Space Mono',monospace;font-size:9px;font-weight:700;
  letter-spacing:.07em;text-transform:uppercase;
  padding:5px 10px;border-radius:3px;
  border:1.5px solid #ccc;color:#888;
  background:transparent;cursor:pointer;transition:all .13s;flex-shrink:0;
}
.edit-btn.on{border-color:#111;color:#111;}

/* Row 2: transport + sound toggles */
.row2{
  display:flex;align-items:center;
  width:100%;padding:6px 12px;gap:6px;
}
.btn{
  font-family:'Space Mono',monospace;font-size:9px;font-weight:700;
  letter-spacing:.05em;text-transform:uppercase;
  padding:5px 10px;border-radius:3px;
  border:1.5px solid #ccc;color:#999;
  background:transparent;cursor:pointer;transition:all .12s;
}
.btn:active{transform:scale(.94);}
.btn.play{border-color:#111;color:#111;}
.btn.play.on{background:#111;color:#fff;}
.btn.rst{border-color:#ccc;color:#999;}
.btn.lp.on{border-color:#111;color:#111;}
.btn.lp.off{border-color:#ddd;color:#ccc;}
.btn.clr{border-color:#ddd;color:#ccc;}

.sep{width:1px;height:18px;background:#e8e8e8;flex-shrink:0;margin:0 2px;}

/* Sound toggles per track */
.snd-btn{
  font-family:'Space Mono',monospace;font-size:8px;font-weight:700;
  letter-spacing:.05em;text-transform:uppercase;
  padding:4px 7px;border-radius:3px;
  border:1.5px solid #ddd;color:#bbb;
  background:transparent;cursor:pointer;transition:all .12s;flex:1;
  white-space:nowrap;
}
.snd-btn.on{border-color:#111;color:#111;}
.snd-btn.off{border-color:#e8e8e8;color:#ccc;}

/* ── TRACK HEADERS ── */
.track-headers{
  display:flex;flex-shrink:0;
  border-bottom:1px solid #e8e8e8;
  height:26px;background:#fafafa;
}
.th-ruler{width:22px;flex-shrink:0;border-right:1px solid #e8e8e8;}
.th-tracks{display:flex;flex:1;}
.th-track{
  flex:1;display:flex;align-items:center;justify-content:center;
  border-right:1px solid #e8e8e8;
  font-size:8px;font-weight:700;letter-spacing:.1em;
  text-transform:uppercase;color:#bbb;
}
.th-track:last-child{border-right:none;}

/* ── ROLL ── */
.roll-wrapper{flex:1;position:relative;overflow:hidden;background:#fff;}
#roll-canvas{position:absolute;top:0;left:0;width:100%;}
#roll-canvas.editing{cursor:crosshair;}

/* Reading line */
.rline{
  position:absolute;left:22px;right:0;height:1.5px;
  background:#111;z-index:10;pointer-events:none;
}
.rline::before{
  content:'';position:absolute;left:-13px;top:-3px;
  width:9px;height:11px;background:#111;
  clip-path:polygon(0 50%,100% 0,100% 100%);
}
.rline-lbl{
  position:absolute;right:6px;top:-8px;
  font-size:7px;color:#bbb;letter-spacing:.1em;
}

/* ── INDICATORS ── */
.indicators{
  display:flex;flex-shrink:0;
  border-top:1px solid #e8e8e8;
  height:56px;padding:7px 8px 7px 30px;gap:6px;
  background:#fafafa;
}
.ind{
  flex:1;border-radius:2px;border:1.5px solid #ddd;
  display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:700;letter-spacing:.05em;
  color:#ccc;
  transition:background .04s,border-color .04s,color .04s;
}
.ind.lit{background:#111;border-color:#111;color:#fff;}

/* Hint */
.hint{
  position:absolute;bottom:8px;left:50%;transform:translateX(-50%);
  font-size:8px;color:#888;letter-spacing:.07em;pointer-events:none;
  opacity:0;transition:opacity .3s;white-space:nowrap;z-index:20;
  background:#ffffffee;padding:3px 9px;border-radius:2px;border:1px solid #e0e0e0;
}
.hint.show{opacity:1;}
</style>
</head>
<body>

<div class="topbar">
  <!-- Row 1 -->
  <div class="row1">
    <div class="logo">Rola</div>
    <div class="bpm-ctrl">
      <span>BPM</span>
      <input type="range" id="bpm-s" min="20" max="200" value="80">
      <span id="bpm-v">80</span>
    </div>
    <button class="edit-btn" id="edit-btn">✏ Editar</button>
  </div>
  <!-- Row 2 -->
  <div class="row2">
    <button class="btn rst" id="b-rst">↺</button>
    <button class="btn play" id="b-play">▶ Play</button>
    <button class="btn lp on" id="b-lp">⟳ Loop</button>
    <button class="btn clr" id="b-clr">Limpiar</button>
    <div class="sep"></div>
    <button class="snd-btn on" id="sb0" onclick="tglSnd(0)">S1</button>
    <button class="snd-btn on" id="sb1" onclick="tglSnd(1)">S2</button>
    <button class="snd-btn on" id="sb2" onclick="tglSnd(2)">S3</button>
    <button class="snd-btn on" id="sb3" onclick="tglSnd(3)">S4</button>
  </div>
</div>

<div class="track-headers">
  <div class="th-ruler"></div>
  <div class="th-tracks">
    <div class="th-track">1</div>
    <div class="th-track">2</div>
    <div class="th-track">3</div>
    <div class="th-track">4</div>
  </div>
</div>

<div class="roll-wrapper" id="wrapper">
  <canvas id="roll-canvas"></canvas>
  <div class="rline" id="rline"><span class="rline-lbl">LDR</span></div>
  <div class="hint" id="hint">TAP = agregar · TAP en cuadrado = borrar · DESLIZAR = scroll</div>
</div>

<div class="indicators" id="inds">
  <div class="ind" id="ind0">1</div>
  <div class="ind" id="ind1">2</div>
  <div class="ind" id="ind2">3</div>
  <div class="ind" id="ind3">4</div>
</div>

<script>
// ── CONFIG ──────────────────────────────────────────────────────
const TRACKS=4,BARS=8,BPB=4,TOTAL=BARS*BPB,SUB=4,SNAP=1/SUB;
const SNAMES=['kick','snare','hihat','tom'];
const RULER=22;
// Square pin dimensions
const SQ=9;   // half-size: square is SQ*2 x SQ*2
const HIT=18; // hit radius in px

// ── STATE ────────────────────────────────────────────────────────
let bpm=80,playing=false,looping=true,editMode=false;
let playhead=0,lastTs=null,raf=null;
let notes=[[],[],[],[]];
let active=[false,false,false,false];
let sndOn=[true,true,true,true];
let wW=0,wH=0,rY=0,ppb=0,tW=0;
let scrollBeat=0;
let pDown=false,pStartY=0,pMoved=false,pScrollRef=0;
let triggered=[new Set(),new Set(),new Set(),new Set()];

// ── DOM ──────────────────────────────────────────────────────────
const canvas=document.getElementById('roll-canvas');
const ctx=canvas.getContext('2d');
const wrapper=document.getElementById('wrapper');
const rline=document.getElementById('rline');
const hint=document.getElementById('hint');
const bPlay=document.getElementById('b-play');
const bRst=document.getElementById('b-rst');
const bLp=document.getElementById('b-lp');
const bClr=document.getElementById('b-clr');
const editBtn=document.getElementById('edit-btn');
const bpmS=document.getElementById('bpm-s');
const bpmV=document.getElementById('bpm-v');
const inds=[0,1,2,3].map(i=>document.getElementById('ind'+i));

// ── DEMO ─────────────────────────────────────────────────────────
function loadDemo(){
  notes=[
    [0,1,2,4,5,6,8,8.5,9.5,10,12,14,16,17,18,20,21,24,25,26,28,29,30],
    [1,3,5,7,9,11,13,15,16,18,20,22,24,26,28,30],
    [0,2,4,4.5,6,8,10,12,14,16,17,18,20,22,24,25,26,28,30],
    [0,4,8,10,12,16,18,20,24,26,28,31],
  ];
}
loadDemo();

// ── LAYOUT ───────────────────────────────────────────────────────
function resize(){
  wW=wrapper.clientWidth; wH=wrapper.clientHeight;
  canvas.width=wW; canvas.height=wH;
  tW=(wW-RULER)/TRACKS;
  rY=Math.round(wH*0.22);
  ppb=wH/(BPB*2.3);
  rline.style.top=rY+'px';
  render();
}

// ── RENDER ───────────────────────────────────────────────────────
function beatY(b){
  const ref=editMode?scrollBeat:playhead;
  return rY-(b-ref)*ppb;
}

function render(){
  ctx.clearRect(0,0,wW,wH);

  // White background
  ctx.fillStyle='#fff';
  ctx.fillRect(0,0,wW,wH);

  // Ruler bg
  ctx.fillStyle='#fafafa';
  ctx.fillRect(0,0,RULER,wH);
  ctx.strokeStyle='#e8e8e8'; ctx.lineWidth=.5;
  ctx.beginPath(); ctx.moveTo(RULER,0); ctx.lineTo(RULER,wH); ctx.stroke();

  // Track separator lines (vertical)
  for(let t=1;t<TRACKS;t++){
    ctx.strokeStyle='#f0f0f0'; ctx.lineWidth=.5;
    ctx.beginPath();
    ctx.moveTo(RULER+t*tW,0); ctx.lineTo(RULER+t*tW,wH);
    ctx.stroke();
  }

  // Grid lines (horizontal)
  const ref=editMode?scrollBeat:playhead;
  // Inverted: beatY(b) = rY - (b-ref)*ppb
  // top of screen (y=0): b = ref + rY/ppb
  // bottom of screen (y=wH): b = ref - (wH-rY)/ppb
  const bTop=ref-(wH-rY)/ppb, bBot=ref+rY/ppb;
  const bS=Math.floor(bTop*SUB)/SUB, bE=Math.ceil(bBot*SUB)/SUB;

  for(let b=bS;b<=bE;b+=SNAP){
    if(b<-SNAP||b>TOTAL+SNAP) continue;
    const y=beatY(b);
    if(y<-2||y>wH+2) continue;
    const isBar=Math.abs(b%BPB)<.001;
    const isBeat=!isBar&&Math.abs(b%1)<.001;
    const isSub=!isBar&&!isBeat;
    if(isSub&&ppb<14) continue;

    // Grid line: bar = #d8d8d8, beat = #ebebeb, subdiv = #f3f3f3
    ctx.strokeStyle=isBar?'#aaaaaa':isBeat?'#cccccc':'#e0e0e0';
    ctx.lineWidth=isBar?.8:.5;
    ctx.beginPath();
    ctx.moveTo(RULER,y); ctx.lineTo(wW,y);
    ctx.stroke();

    // Bar numbers
    if(isBar&&b>=0&&b<=TOTAL){
      const bar=Math.round(b/BPB);
      ctx.fillStyle='#c8c8c8';
      ctx.font='8px Space Mono,monospace';
      ctx.textAlign='center';
      ctx.fillText(bar+1, RULER/2, y+10);
    }
  }

  // End marker
  const ey=beatY(TOTAL);
  if(ey>-2&&ey<wH+2){
    ctx.strokeStyle='#ccc'; ctx.lineWidth=1;
    ctx.setLineDash([4,3]);
    ctx.beginPath(); ctx.moveTo(RULER,ey); ctx.lineTo(wW,ey); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle='#ccc'; ctx.font='7px Space Mono,monospace'; ctx.textAlign='left';
    ctx.fillText('FIN',RULER+3,ey-3);
  }

  // Edit guide at readingY
  if(editMode){
    ctx.strokeStyle='#e0e0e0'; ctx.lineWidth=1;
    ctx.setLineDash([3,3]);
    ctx.beginPath(); ctx.moveTo(RULER,rY); ctx.lineTo(wW,rY); ctx.stroke();
    ctx.setLineDash([]);
  }

  // ── SQUARES (notas) ──
  for(let t=0;t<TRACKS;t++){
    const cx2=RULER+t*tW+tW/2;
    for(const beat of notes[t]){
      const y=beatY(beat);
      if(y<-SQ-10||y>wH+SQ+10) continue;
      const lit=!editMode&&active[t]&&Math.abs(beat-playhead)<.12;

      // Tick line across track (gray)
      ctx.strokeStyle='#e0e0e0'; ctx.lineWidth=.5;
      ctx.beginPath();
      ctx.moveTo(RULER+t*tW+4,y); ctx.lineTo(RULER+(t+1)*tW-4,y);
      ctx.stroke();

      // Square: black when normal, inverted (white + border) when lit
      const half=SQ;
      if(lit){
        // Active: white square with black border + black fill flash
        ctx.fillStyle='#111';
        ctx.fillRect(cx2-half,y-half,half*2,half*2);
      } else {
        ctx.fillStyle='#111';
        ctx.fillRect(cx2-half,y-half,half*2,half*2);
      }

      // Inner highlight dot when lit
      if(lit){
        ctx.fillStyle='#fff';
        ctx.fillRect(cx2-3,y-3,6,6);
      }
    }
  }
}

// ── TRIGGERS ─────────────────────────────────────────────────────
const TWIN=0.08;
function checkTriggers(){
  for(let t=0;t<TRACKS;t++){
    let any=false;
    for(const beat of notes[t]){
      const d=playhead-beat;
      if(d>=0&&d<TWIN){
        any=true;
        const k=beat.toFixed(4);
        if(!triggered[t].has(k)){ triggered[t].add(k); trigSnd(t); }
      }
    }
    if(any!==active[t]){ active[t]=any; inds[t].classList.toggle('lit',any); }
  }
}
function clearTrig(){ triggered=[new Set(),new Set(),new Set(),new Set()]; }

// ── PLAYBACK ─────────────────────────────────────────────────────
function startPlay(){
  getAC(); playing=true; lastTs=null;
  bPlay.textContent='⏸ Pausa'; bPlay.classList.add('on');
  raf=requestAnimationFrame(loop);
}
function pausePlay(){
  playing=false;
  bPlay.textContent='▶ Play'; bPlay.classList.remove('on');
  cancelAnimationFrame(raf);
  active=[false,false,false,false];
  inds.forEach(i=>i.classList.remove('lit'));
}
function loop(ts){
  if(!playing) return;
  if(lastTs!==null){
    playhead+=(ts-lastTs)/1000*(bpm/60);
    if(playhead>=TOTAL){
      if(looping){ playhead-=TOTAL; clearTrig(); }
      else{ playhead=TOTAL; pausePlay(); render(); return; }
    }
  }
  lastTs=ts; checkTriggers(); render();
  raf=requestAnimationFrame(loop);
}

// ── EDIT POINTER ─────────────────────────────────────────────────
function ptCoords(e){
  const r=canvas.getBoundingClientRect();
  const src=e.changedTouches?e.changedTouches[0]:e;
  const px=src.clientX-r.left, py=src.clientY-r.top;
  const t=Math.floor((px-RULER)/tW);
  // inverted: beat = scrollBeat + (rY - py) / ppb
  const rawBeat=scrollBeat+(rY-py)/ppb;
  const snapped=Math.round(rawBeat*SUB)/SUB;
  return{t:Math.max(0,Math.min(TRACKS-1,t)),beat:snapped,py,valid:px>=RULER};
}
function nearPin(t,beat){
  const tol=HIT/ppb;
  return notes[t].findIndex(b=>Math.abs(b-beat)<=tol);
}

canvas.addEventListener('pointerdown',e=>{
  if(!editMode) return;
  e.preventDefault();
  canvas.setPointerCapture(e.pointerId);
  const{py}=ptCoords(e);
  pDown=true; pStartY=py; pMoved=false; pScrollRef=scrollBeat;
});
canvas.addEventListener('pointermove',e=>{
  if(!editMode||!pDown) return;
  e.preventDefault();
  const{py}=ptCoords(e);
  const dy=py-pStartY;
  if(Math.abs(dy)>8){
    pMoved=true;
    // inverted: drag down = scroll to earlier beats (scrollBeat decreases)
    scrollBeat=pScrollRef+dy/ppb;
    const minB=-(rY/ppb), maxB=TOTAL+(wH-rY)/ppb;
    scrollBeat=Math.max(minB,Math.min(maxB,scrollBeat));
    render();
  }
});
canvas.addEventListener('pointerup',e=>{
  if(!editMode||!pDown) return;
  e.preventDefault();
  pDown=false;
  if(pMoved) return;
  const{t,beat,valid}=ptCoords(e);
  if(!valid||beat<0||beat>TOTAL) return;
  const idx=nearPin(t,beat);
  if(idx>=0) notes[t].splice(idx,1);
  else{
    const s=Math.round(beat*SUB)/SUB;
    if(s>=0&&s<TOTAL){ notes[t].push(s); notes[t].sort((a,b)=>a-b); }
  }
  trigSnd(t); render();
});

// ── CONTROLS ─────────────────────────────────────────────────────
bPlay.addEventListener('click',()=>{ if(playing) pausePlay(); else startPlay(); });
bRst.addEventListener('click',()=>{ pausePlay(); playhead=0; scrollBeat=0; clearTrig(); render(); });
bLp.addEventListener('click',()=>{
  looping=!looping;
  bLp.classList.toggle('on',looping); bLp.classList.toggle('off',!looping);
});
bClr.addEventListener('click',()=>{ notes=[[],[],[],[]]; render(); });
editBtn.addEventListener('click',()=>{
  editMode=!editMode;
  editBtn.classList.toggle('on',editMode);
  editBtn.textContent=editMode?'✓ Listo':'✏ Editar';
  canvas.classList.toggle('editing',editMode);
  if(editMode){
    pausePlay();
    scrollBeat=playhead+(rY/ppb); pScrollRef=scrollBeat;
    hint.classList.add('show');
    setTimeout(()=>hint.classList.remove('show'),3500);
  }
  render();
});
bpmS.addEventListener('input',()=>{ bpm=parseInt(bpmS.value); bpmV.textContent=bpm; });

// ── SOUND ────────────────────────────────────────────────────────
let ac=null;
function getAC(){
  if(!ac) ac=new(window.AudioContext||window.webkitAudioContext)();
  if(ac.state==='suspended') ac.resume(); return ac;
}
function playKick(a,t){
  const o=a.createOscillator(),g=a.createGain();
  o.connect(g);g.connect(a.destination);
  o.frequency.setValueAtTime(150,t);o.frequency.exponentialRampToValueAtTime(38,t+.08);
  g.gain.setValueAtTime(1,t);g.gain.exponentialRampToValueAtTime(.001,t+.32);
  o.start(t);o.stop(t+.32);
  const buf=a.createBuffer(1,a.sampleRate*.02,a.sampleRate),d=buf.getChannelData(0);
  for(let i=0;i<d.length;i++) d[i]=(Math.random()*2-1)*(1-i/d.length);
  const s=a.createBufferSource(),g2=a.createGain();
  s.buffer=buf;s.connect(g2);g2.connect(a.destination);
  g2.gain.setValueAtTime(.35,t);g2.gain.exponentialRampToValueAtTime(.001,t+.02);s.start(t);
}
function playSnare(a,t){
  const o=a.createOscillator(),og=a.createGain();
  o.connect(og);og.connect(a.destination);
  o.frequency.setValueAtTime(200,t);o.frequency.exponentialRampToValueAtTime(100,t+.1);
  og.gain.setValueAtTime(.5,t);og.gain.exponentialRampToValueAtTime(.001,t+.13);
  o.start(t);o.stop(t+.13);
  const len=a.sampleRate*.16,buf=a.createBuffer(1,len,a.sampleRate),data=buf.getChannelData(0);
  for(let i=0;i<len;i++) data[i]=Math.random()*2-1;
  const s=a.createBufferSource(),f=a.createBiquadFilter(),ng=a.createGain();
  s.buffer=buf;f.type='highpass';f.frequency.value=2000;
  s.connect(f);f.connect(ng);ng.connect(a.destination);
  ng.gain.setValueAtTime(.65,t);ng.gain.exponentialRampToValueAtTime(.001,t+.16);s.start(t);
}
function playHihat(a,t){
  const len=Math.floor(a.sampleRate*.07),buf=a.createBuffer(1,len,a.sampleRate),data=buf.getChannelData(0);
  for(let i=0;i<len;i++) data[i]=Math.random()*2-1;
  const s=a.createBufferSource(),f=a.createBiquadFilter(),g=a.createGain();
  s.buffer=buf;f.type='highpass';f.frequency.value=7500;
  s.connect(f);f.connect(g);g.connect(a.destination);
  g.gain.setValueAtTime(.38,t);g.gain.exponentialRampToValueAtTime(.001,t+.05);s.start(t);
}
function playTom(a,t){
  const o=a.createOscillator(),g=a.createGain();
  o.connect(g);g.connect(a.destination);
  o.frequency.setValueAtTime(200,t);o.frequency.exponentialRampToValueAtTime(72,t+.14);
  g.gain.setValueAtTime(.75,t);g.gain.exponentialRampToValueAtTime(.001,t+.22);
  o.start(t);o.stop(t+.22);
}
const SFNS=[playKick,playSnare,playHihat,playTom];
function trigSnd(t){ if(!sndOn[t]) return; const a=getAC(); SFNS[t](a,a.currentTime); }
function tglSnd(t){
  sndOn[t]=!sndOn[t];
  const b=document.getElementById('sb'+t),on=sndOn[t];
  b.classList.toggle('on',on); b.classList.toggle('off',!on);
  b.textContent=on?`S${t+1}`:`S${t+1}`;
  b.style.textDecoration=on?'none':'line-through';
}

// ── INIT ─────────────────────────────────────────────────────────
window.addEventListener('resize',resize);
resize();
</script>
</body>
</html>
